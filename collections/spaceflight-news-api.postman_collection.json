  "info": {
    "_postman_id": "fc342b9f-1656-4998-a1c0-1892146e8195",
    "name": "Spaceflight News API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Spaceflight News API (SNAPI) is a free, open REST API aggregating space-related news, blogs, and reports from over 43 sources including NASA, SpaceX, Reuters, NASASpaceflight, and Spaceflight Now. It provides paginated access to articles, blogs, and reports, with integration to Launch Library 2 for linking content to specific launches and events. No authentication is required.\n\nContact Support:\n Name: The Space Devs",
      "type": "text/plain"
    }
  }
